# Plantilla de entorno para Crypto Engine V5.
# Copiar a .env y rellenar. NUNCA subir .env con secretos reales (CE-13).
# Las variables concretas (DB, Redis, etc.) se anaden cuando su pieza las
# necesite; en P00 el esqueleto solo declara el entorno de ejecucion.
CE_V5_ENV=development
# Persistencia (P02b/P05). DOS roles distintos (ADR-011):
#   - rol de aplicacion: se conecta en runtime, SIN BYPASSRLS ni SUPERUSER.
#   - rol de migraciones: crea/altera tablas; NUNCA corre en runtime.
CE_V5_DATABASE_URL=postgresql://ce_v5_app:CAMBIAME@localhost:5432/ce_v5
CE_V5_MIGRATIONS_DATABASE_URL=postgresql://ce_v5:ce_v5@localhost:5432/ce_v5
# Contrasena del rol de aplicacion; la usa "python -m ce_v5.infra.db.provision".
CE_V5_APP_DB_PASSWORD=CAMBIAME
# Rol de OPERADOR (P06/CA-03): solo para la herramienta de operador; NUNCA en
# procesos de runtime (api/workers). from_env aborta si esta presente en runtime.
#
# EL PROCESO DE LA API JAMAS DEBE LLEVAR ESTA VARIABLE, y no es una recomendacion: el
# guardia de arranque LO IMPIDE. Si CE_V5_OPERATOR_DATABASE_URL esta en el entorno de la
# API, DbConfig.from_env lanza OperatorDsnInRuntimeError y el proceso NO ARRANCA. Una
# puerta publica que porte la credencial capaz de tocar kill switches y publicar politica
# convierte cualquier fallo de la API en un compromiso total de la plataforma.
#
# POR ESO LA VALIDACION EN CALIENTE EXIGE TRES TERMINALES, cada una con su entorno:
#   1) API      : python -m ce_v5.entrypoints.api          (SIN el DSN de operador)
#   2) arnes    : python tools/validate_p06b_api.py        (cliente HTTP/WebSocket)
#   3) operador : python -m ce_v5.entrypoints.operator_cli (CON el DSN de operador)
# No es ceremonia: es la separacion de poderes, hecha visible. Si las tres cupieran en
# una sola terminal, el DSN de operador estaria en el entorno de la API.
CE_V5_OPERATOR_DATABASE_URL=postgresql://ce_v5_operator:CAMBIAME@localhost:5432/ce_v5
CE_V5_OPERATOR_DB_PASSWORD=CAMBIAME
# Bus (P03).
CE_V5_REDIS_URL=redis://localhost:6379/0
# Autenticacion (P06b, ADR-019). El secreto FIRMA los tokens de acceso: si se filtra,
# cualquiera puede fabricarse un pase valido. Minimo 32 caracteres; la aplicacion se
# NIEGA a arrancar si falta o es corto. Generalo aleatorio, nunca lo reutilices entre
# entornos y NUNCA lo subas al repositorio (CE-13).
CE_V5_JWT_SECRET=CAMBIAME_POR_UN_SECRETO_ALEATORIO_DE_32_O_MAS
# Vida del token de ACCESO en segundos (corta a proposito: 15 min).
CE_V5_ACCESS_TOKEN_TTL_SECONDS=900
# Vida del REFRESH token en segundos (14 dias).
CE_V5_REFRESH_TOKEN_TTL_SECONDS=1209600
# API (P06b). La API es un proceso propio (ADR-002): "python -m ce_v5.entrypoints.api".
CE_V5_API_HOST=127.0.0.1
CE_V5_API_PORT=8000
# Limitador de intentos (P06b, CA-10). Con este secreto se calculan las HUELLAS del email
# y de la IP que se usan como claves en Redis: el almacen NUNCA contiene emails ni IPs en
# claro. Minimo 32 caracteres, aleatorio, nunca en el repositorio (CE-13).
CE_V5_RATE_LIMIT_SECRET=CAMBIAME_POR_UN_SECRETO_ALEATORIO_DE_32_O_MAS
# Cuantos proxies PROPIOS hay delante de la API. 0 = ninguno: se IGNORA X-Forwarded-For y
# se usa la IP de la conexion (valor SEGURO). Poner un numero mayor solo si de verdad hay
# esa cantidad de proxies de confianza delante; si no, cualquiera podria falsificar su IP.
CE_V5_TRUSTED_PROXY_COUNT=0
# Origenes admitidos para CORS, separados por coma. VACIO por defecto: hoy no hay cliente
# web (es P12a) y no se monta CORS "por si acaso". Un "*" esta PROHIBIDO y la aplicacion
# NO ARRANCA con el: con credenciales, un comodin permitiria a cualquier web del mundo
# hacer peticiones autenticadas con la cookie del usuario.
CE_V5_CORS_ALLOWED_ORIGINS=
# Cookies solo por HTTPS. Se puede poner a false para desarrollar sin HTTPS; en
# produccion la aplicacion NO ARRANCA con false (la cookie viajaria en claro).
CE_V5_COOKIE_SECURE=true
# Tamano maximo del cuerpo de una peticion, en bytes. Se rechaza ANTES de leerlo.
CE_V5_MAX_BODY_BYTES=65536
